#!/usr/bin/env bash
#
# Client pre-commit hook for SDL governance.
# Infers the issue from the branch name and validates staged paths against
# the routing attestation. Commit-message trailer validation happens in the
# commit-msg hook because Git does not reliably expose the message here.

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)

python3 "$REPO_ROOT/.stibdedlom/bin/validate-pre-commit.py" \
    --repo-root "$REPO_ROOT"
